# Copy this to .env and fill in your values

# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=your-api-key-here

# Server port
PORT=3000

# Encryption key for sensitive data (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# Twilio Configuration (get from console.twilio.com)
# Set TWILIO_ENABLED=true to enable real SMS
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# DoorDash browser automation settings
DOORDASH_HEADLESS=false
BROWSER_DATA_DIR=./browser-data

# frog Skill APIs
# Weather: free key at openweathermap.org/api
OPENWEATHER_API_KEY=

# News: free key at newsapi.org
NEWS_API_KEY=

# Google Calendar OAuth (console.cloud.google.com → APIs & Services → Credentials)
# Create OAuth client ID (Web app), redirect URI: http://localhost:3000/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Spotify (developer.spotify.com/dashboard → Create App)
# Redirect URI: http://localhost:3000/oauth/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ── frog Voice Settings ──────────────────────────────────────────────────────

# Voice gender: "female" (af_heart) or "male" (am_michael)
FROG_VOICE=female

# Mic thresholds — run 'python scripts/calibrate.py' to auto-detect for your mic
# These defaults work well for a USB lapel mic on Pi
# Increase SPEECH_THRESHOLD if frog triggers on ambient noise
# Decrease SPEECH_THRESHOLD if frog misses your voice
SPEECH_THRESHOLD=300
SILENCE_THRESHOLD=100

# Pi device ID — used as the conversation user for the voice endpoint
# No need to change this unless running multiple frog devices on the same server
PI_DEVICE_ID=+1PIDEVICE000
