# Copy this to .env and fill in your values

# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=your-api-key-here

# Server port
PORT=3000

# Encryption key for sensitive data (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# TextBelt Configuration (get key from textbelt.com)
# Set TEXTBELT_ENABLED=true to enable real SMS
TEXTBELT_ENABLED=false
TEXTBELT_KEY=your-textbelt-key

# Public URL of this server (needed for SMS reply webhooks)
# Use ngrok for local dev: ngrok http 3000 -> paste the https URL here
SERVER_URL=https://your-server-url.com
